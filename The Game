<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Sentinel: The Great Escape</title>
    <style>
        :root {
            --jungle-dark: #1a2f15;
            --jungle-leaf: #2d5a27;
            --wood: #5d4037;
            --sky: #4a7c44;
            --sand: #f2d16b;
            --ocean: #2e91e5;
            --deep-blue: #1565c0;
        }

        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: var(--jungle-dark);
            font-family: 'Courier New', Courier, monospace;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            touch-action: none;
        }

        #game-container {
            position: relative;
            width: 100%;
            height: 100%;
            max-width: 900px;
            max-height: 500px;
            background-color: var(--sky);
            border: 4px solid var(--jungle-dark);
            box-shadow: 0 0 50px rgba(0,0,0,0.8);
            overflow: hidden;
        }

        canvas {
            display: block;
            image-rendering: pixelated;
        }

        #ui {
            position: absolute;
            top: 15px;
            left: 15px;
            right: 15px;
            pointer-events: none;
            display: flex;
            justify-content: space-between;
            color: #fff;
            text-shadow: 2px 2px #000;
            font-size: 1.5rem;
            z-index: 5;
        }

        .screen {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            z-index: 10;
            text-align: center;
        }

        .btn {
            background: #4caf50;
            border: none;
            border-bottom: 4px solid #2e7d32;
            color: white;
            padding: 15px 35px;
            font-size: 1.8rem;
            cursor: pointer;
            border-radius: 4px;
            margin-top: 20px;
            pointer-events: auto;
        }

        .btn:active {
            transform: translateY(2px);
            border-bottom-width: 2px;
        }

        #controls-hint {
            margin-top: 15px;
            font-size: 0.9rem;
            color: #ccc;
        }
    </style>
</head>
<body>

<div id="game-container">
    <div id="ui" style="display: none;">
        <div id="level-indicator">Level 1: Jungle</div>
        <div id="score">0/4050m</div>
        <div id="lives">HP: ❤️❤️❤️❤️❤️</div>
    </div>

    <canvas id="gameCanvas"></canvas>

    <div id="start-screen" class="screen">
        <h1 style="color: #81c784; font-size: 3.5rem; margin-bottom: 0;">Sentinel: The Great Escape</h1>
        <p>Rescue John C. Green from the Islanders</p>
        <button class="btn" id="start-btn" onclick="startSequence(1)">START MISSION</button>
        <div id="controls-hint">
            WASD / Arrows: Move & Jump<br>
            Reach the goals to progress the story!
        </div>
    </div>

    <div id="game-over-screen" class="screen" style="display: none;">
        <h1 id="death-title" style="color: #e57373;">CAUGHT!</h1>
        <p id="final-stats">Progress: 0m</p>
        <button class="btn" onclick="retryFromCheckpoint()">RETRY FROM CHECKPOINT</button>
        <button class="btn" style="background: #555; border-color: #333; font-size: 1rem; padding: 10px 20px;" onclick="location.reload()">RESTART ALL</button>
    </div>

    <div id="victory-screen" class="screen" style="display: none;">
        <h1 style="color: #ffeb3b;">MISSION ACCOMPLISHED</h1>
        <p>John C. Green is safe!</p>
        <button class="btn" onclick="location.reload()">PLAY AGAIN</button>
    </div>
</div>

<script>
    // --- Audio Engine ---
    const AudioEngine = (() => {
        let audioCtx = null;
        let gainNode = null;
        let sequenceInterval = null;
        let currentTrack = null;

        const scales = {
            mystery: [220, 233, 261, 277, 311, 329], 
            jungle: [164, 196, 220, 246, 293],      
            ocean: [329, 392, 440, 493, 587, 659],   
            boss: [110, 116, 123, 138, 146]          
        };

        function init() {
            if (audioCtx) return;
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            gainNode = audioCtx.createGain();
            gainNode.connect(audioCtx.destination);
            gainNode.gain.value = 0.05; 
        }

        function playTone(freq, duration) {
            if (!audioCtx) return;
            const osc = audioCtx.createOscillator();
            const g = audioCtx.createGain();
            osc.type = 'square';
            osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            osc.connect(g);
            g.connect(gainNode);
            g.gain.setValueAtTime(0.1, audioCtx.currentTime);
            g.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);
            osc.start();
            osc.stop(audioCtx.currentTime + duration);
        }

        function playTrack(name) {
            init();
            if (currentTrack === name) return;
            stop();
            currentTrack = name;
            let step = 0;
            const scale = scales[name] || scales.mystery;
            const tempo = name === 'jungle' ? 150 : (name === 'boss' ? 120 : 200);

            sequenceInterval = setInterval(() => {
                const note = scale[Math.floor(Math.random() * scale.length)];
                if (step % 4 === 0) playTone(note / 2, 0.4); 
                else if (Math.random() > 0.4) playTone(note, 0.2); 
                step++;
            }, tempo);
        }

        function stop() {
            if (sequenceInterval) clearInterval(sequenceInterval);
            currentTrack = null;
        }

        return { playTrack, stop, init };
    })();

    // --- Game Logic ---
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const startScreen = document.getElementById('start-screen');
    const gameOverScreen = document.getElementById('game-over-screen');
    const victoryScreen = document.getElementById('victory-screen');
    const scoreText = document.getElementById('score');
    const livesText = document.getElementById('lives');
    const levelIndicator = document.getElementById('level-indicator');
    const ui = document.getElementById('ui');

    const GRAVITY = 0.35; 
    const JUMP_FORCE = -11; 
    const SPEED = 5;
    const RAFT_SPEED = 3;
    const MAX_HP = 5;

    const JUNGLE_GOAL = 4050; 
    const RAFT_GOAL = 2430; 

    let gameState = 'MENU';
    let currentLevel = 1;
    let lastCheckpoint = 1;
    let cameraX = 0;
    let score = 0;
    let keys = {};
    let dialogue = "";
    
    let player = {
        x: 100, y: 200, w: 32, h: 48,
        vx: 0, vy: 0,
        grounded: false,
        hp: MAX_HP,
        facing: 1,
        invincible: false
    };

    let platforms = [];
    let enemies = [];
    let arrows = [];
    let items = [];

    let cutsceneTimer = 0;
    let boatPos = { x: 800, y: 400 };
    let doctorPos = { x: 500, y: 390 };
    let islandersCutscene = [];
    let kevin = { x: 0, y: 0, w: 32, h: 40, hp: 3, lastShot: 0, dir: 1, vx: 2 };
    let bossArenaBounds = { minX: 0, maxX: 0 };
    let endTextY = -100;

    const DIALOGUE_DURATION = 240; // 4 seconds at 60fps

    function initLevel1() {
        platforms = []; enemies = []; arrows = []; items = [];
        currentLevel = 1; lastCheckpoint = 1;
        levelIndicator.innerText = "Level 1: Jungle";
        platforms.push({x: 0, y: 440, w: 50000, h: 60, type: 'ground'});
        
        for (let i = 0; i < 200; i++) {
            let px = 800 + (i * 220);
            if (px > 45000) break;
            
            if (Math.random() > 0.5) {
                let py = 330 - (Math.random() * 120);
                let pw = 150 + (Math.random() * 100);
                platforms.push({x: px, y: py, w: pw, h: 30, type: 'platform'});
                if (Math.random() > 0.6) enemies.push(createEnemy(px + 20, py - 40, pw - 60));
            } else {
                enemies.push(createEnemy(px, 440 - 40, 200));
            }
        }
    }

    function initLevel2() {
        platforms = []; enemies = []; arrows = []; items = [];
        currentLevel = 2; lastCheckpoint = 2;
        levelIndicator.innerText = "Level 2: Rafts";
        cameraX = 0; player.x = 100; player.y = 300;
        score = 405; 
        
        for (let i = 0; i < 500; i++) {
            let px = i * 250;
            let py = 350 + (Math.sin(i) * 50);
            let pw = 100 + (Math.random() * 80);
            platforms.push({x: px, y: py, w: pw, h: 25, type: 'raft'});
            if (i > 2 && Math.random() > 0.6) enemies.push(createEnemy(px + 10, py - 40, pw - 40));
        }
    }

    function createEnemy(x, y, range) {
        return {
            x: x, y: y, baseX: x, range: range,
            dir: 1, w: 32, h: 40,
            lastShot: 0, shootInterval: 2000 + Math.random() * 2000,
            squished: false, squishTimer: 0
        };
    }

    function startSequence(lvl) {
        AudioEngine.playTrack('mystery');
        dialogue = "";
        cutsceneTimer = 0;
        if (lvl === 1) {
            gameState = 'CUTSCENE1';
            player.x = -50; player.y = 440 - 48;
            initLevel1();
        } else if (lvl === 2) {
            gameState = 'CUTSCENE2';
            initLevel2();
            boatPos = { x: 400, y: 380 };
        } else if (lvl === 3) {
            lastCheckpoint = 3;
            gameState = 'CUTSCENE3';
            boatPos = { x: player.x + 500, y: 300 };
            islandersCutscene = [
                {x: player.x + 520, y: boatPos.y - 40, vy: 0, off: false},
                {x: player.x + 560, y: boatPos.y - 40, vy: 0, off: false},
                {x: player.x + 540, y: boatPos.y - 40, vy: 0, off: false, isKevin: true}
            ];
            doctorPos = { x: boatPos.x + 50, y: boatPos.y - 48 };
            platforms = [{x: player.x - 200, y: 440, w: 1200, h: 60, type: 'raft-arena'}];
            bossArenaBounds = { minX: player.x - 200, maxX: player.x + 1000 };
            player.y = 440 - player.h;
        }
        
        player.hp = MAX_HP;
        player.invincible = false;
        if (lvl !== 3) cameraX = player.x - 100;
        
        startScreen.style.display = 'none';
        gameOverScreen.style.display = 'none';
        victoryScreen.style.display = 'none';
        ui.style.display = 'none';
        requestAnimationFrame(gameLoop);
    }

    function retryFromCheckpoint() {
        startSequence(lastCheckpoint);
    }

    function startGame() {
        if (currentLevel === 1) AudioEngine.playTrack('jungle');
        else AudioEngine.playTrack('ocean');
        gameState = currentLevel === 1 ? 'LEVEL1' : 'LEVEL2';
        dialogue = "";
        ui.style.display = 'flex';
        updateUI();
    }

    function updateUI() {
        if (currentLevel === 1) {
            const displayScore = Math.min(JUNGLE_GOAL, Math.floor(score * 10));
            scoreText.innerText = `${displayScore}/${JUNGLE_GOAL}m`;
        } else {
            const displayScore = Math.min(RAFT_GOAL, Math.floor((score - 405) * 10));
            scoreText.innerText = `${displayScore}/${RAFT_GOAL}m`;
        }
        livesText.innerText = `HP: ${'❤️'.repeat(player.hp)}${'🖤'.repeat(MAX_HP-player.hp)}`;
    }

    window.addEventListener('keydown', e => keys[e.code] = true);
    window.addEventListener('keyup', e => keys[e.code] = false);

    function checkCollision(obj1, obj2) {
        return obj1.x < obj2.x + obj2.w &&
               obj1.x + obj1.w > obj2.x &&
               obj1.y < obj2.y + obj2.h &&
               obj1.y + obj1.h > obj2.y;
    }

    function gameLoop() {
        if (gameState === 'MENU' || gameState === 'GAMEOVER' || gameState === 'VICTORY') return;
        if (gameState === 'CUTSCENE1') updateCutscene1();
        else if (gameState === 'CUTSCENE2') updateCutscene2();
        else if (gameState === 'CUTSCENE3') updateCutscene3();
        else if (gameState === 'BOSS_BATTLE') updateBossBattle();
        else if (gameState === 'CUTSCENE4') updateCutscene4();
        else updatePhysics();
        draw();
        requestAnimationFrame(gameLoop);
    }

    function updateCutscene1() {
        cutsceneTimer++;
        if (cutsceneTimer < 80) {
            player.x += 1.5;
            if (cutsceneTimer > 20 && cutsceneTimer < 20 + DIALOGUE_DURATION) dialogue = "Is this...North Sentinel Island?!?!?";
            else dialogue = "";
        } else if (cutsceneTimer === 80) {
            dialogue = ""; doctorPos = { x: 400, y: 440 - 48 };
            islandersCutscene = [{x: 440, y: 400, off: false}, {x: 360, y: 400, off: false}];
        } else if (cutsceneTimer < 80 + DIALOGUE_DURATION + 100) {
            doctorPos.x += 2; islandersCutscene.forEach(isl => isl.x += 2);
            if (cutsceneTimer > 100 && cutsceneTimer < 100 + DIALOGUE_DURATION) dialogue = "IS THAT JOHN C GREEN? I MUST SAVE HIM!";
            else if (cutsceneTimer >= 100 + DIALOGUE_DURATION) dialogue = "";
        } else { dialogue = ""; startGame(); }
    }

    function updateCutscene2() {
        cutsceneTimer++; cameraX = 0;
        if (cutsceneTimer === 1) {
            doctorPos = { x: 420, y: 380 - 48 };
            boatPos = { x: 400, y: 380 };
            islandersCutscene = [{x: 450, y: 380 - 40, off: false}, {x: 390, y: 380 - 40, off: false}];
        }
        if (cutsceneTimer > 50 && cutsceneTimer < 250) {
            boatPos.x += 1.5; doctorPos.x += 1.5;
            islandersCutscene.forEach(isl => isl.x += 1.5);
        } else if (cutsceneTimer >= 250) { initLevel2(); startGame(); }
    }

    function updateCutscene3() {
        cutsceneTimer++;
        if (cutsceneTimer > 50 && cutsceneTimer < 150) {
            islandersCutscene.forEach(isl => {
                if (!isl.isKevin) { isl.off = true; isl.vy += 0.5; isl.y += isl.vy; isl.x += 1; }
            });
        }
        
        const line1Start = 160;
        const line2Start = line1Start + DIALOGUE_DURATION;
        const battleStart = line2Start + DIALOGUE_DURATION;

        if (cutsceneTimer >= line1Start && cutsceneTimer < line2Start) {
            dialogue = "KEVIN DEANDRADE NOOOOOO.";
        } else if (cutsceneTimer >= line2Start && cutsceneTimer < battleStart) {
            dialogue = "imma cut him up like im giving him open heart surgery MWHAHAH";
        } else if (cutsceneTimer === battleStart) {
            dialogue = ""; boatPos.x += 200; doctorPos.x += 200;
            AudioEngine.playTrack('boss');
            gameState = 'BOSS_BATTLE';
            kevin = { x: player.x + 500, y: 440 - 40, w: 32, h: 40, hp: 3, lastShot: 0, dir: 1, vx: 2 };
            ui.style.display = 'flex';
            levelIndicator.innerText = "FINAL BOSS: KEVIN";
        }
    }

    function updateBossBattle() {
        updatePhysics();
        kevin.x += kevin.vx * kevin.dir;
        
        if (kevin.x < bossArenaBounds.minX) {
            kevin.x = bossArenaBounds.minX;
            kevin.dir = 1;
        } else if (kevin.x + kevin.w > bossArenaBounds.maxX) {
            kevin.x = bossArenaBounds.maxX - kevin.w;
            kevin.dir = -1;
        }

        const now = Date.now();
        if (now - kevin.lastShot > 660) {
            arrows.push({ x: kevin.x, y: kevin.y + 15, vx: (player.x < kevin.x) ? -12 : 12, w: 15, h: 4, isBullet: true });
            kevin.lastShot = now;
        }

        if (checkCollision(player, kevin)) {
            if (player.vy > 0 && player.y + player.h - player.vy < kevin.y + 15) {
                kevin.hp--; player.vy = JUMP_FORCE;
                if (kevin.hp <= 0) {
                    AudioEngine.playTrack('mystery');
                    gameState = 'CUTSCENE4'; cutsceneTimer = 0;
                    ui.style.display = 'none';
                }
            } else if (!player.invincible) takeDamage();
        }
    }

    function updateCutscene4() {
        cutsceneTimer++;
        if (cutsceneTimer < DIALOGUE_DURATION) {
            dialogue = "And he says he's from the mean streets of Mumbai";
        } else if (cutsceneTimer === DIALOGUE_DURATION) {
            dialogue = "";
        }
        
        if (cutsceneTimer > DIALOGUE_DURATION + 60 && cutsceneTimer < DIALOGUE_DURATION + 190) { 
            player.x += 1; player.facing = 1; 
        }
        
        if (cutsceneTimer === DIALOGUE_DURATION + 190) { 
            dialogue = ""; boatPos.y = 400; boatPos.x = player.x - 20; 
        }

        if (cutsceneTimer > DIALOGUE_DURATION + 200) {
            boatPos.x += 4; player.x = boatPos.x + 20; player.y = boatPos.y - 48;
            doctorPos.x = boatPos.x + 50; doctorPos.y = boatPos.y - 48;
            cameraX = boatPos.x - 300; if (endTextY < canvas.height / 2) endTextY += 2;
        }
        if (cutsceneTimer > DIALOGUE_DURATION + 640) { AudioEngine.stop(); gameState = 'VICTORY'; victoryScreen.style.display = 'flex'; }
    }

    function updatePhysics() {
        player.vx = 0;
        const currentSpeed = (currentLevel === 2) ? RAFT_SPEED : SPEED;
        if (keys['ArrowLeft'] || keys['KeyA']) { player.vx = -currentSpeed; player.facing = -1; }
        if (keys['ArrowRight'] || keys['KeyD']) { player.vx = currentSpeed; player.facing = 1; }
        if ((keys['Space'] || keys['ArrowUp'] || keys['KeyW']) && player.grounded) { player.vy = JUMP_FORCE; player.grounded = false; }
        player.vy += GRAVITY; player.x += player.vx; player.y += player.vy; player.grounded = false;
        
        platforms.forEach(p => {
            if (checkCollision(player, p)) {
                if (player.vy > 0 && player.y + player.h - player.vy <= p.y) { player.y = p.y - player.h; player.vy = 0; player.grounded = true; }
            }
        });

        // CAMERA LOGIC
        if (gameState === 'BOSS_BATTLE') {
            // Camera centers on James during boss battle
            cameraX = player.x - canvas.width / 2;
            
            // Also enforce arena boundaries for James
            if (player.x < bossArenaBounds.minX || player.x + player.w > bossArenaBounds.maxX) {
                if (player.y > 440) endGame("DROWNED!");
            }
        } else {
            // Standard progressive camera
            cameraX = Math.max(cameraX, player.x - 300);
        }

        score = Math.max(score, (player.x - 100) / 10);
        updateUI();

        if (gameState === 'LEVEL1' && score >= 405) { startSequence(2); return; }
        if (gameState === 'LEVEL2' && score >= 648) { startSequence(3); return; }
        if (gameState === 'LEVEL2' && player.y > 440) { endGame("DROWNED!"); return; }

        enemies.forEach((e, idx) => {
            if (e.squished) { if (++e.squishTimer > 20) enemies.splice(idx, 1); return; }
            e.x += e.dir * 1.5; if (e.x > e.baseX + e.range || e.x < e.baseX) e.dir *= -1;
            if (checkCollision(player, e)) {
                if (player.vy > 0 && player.y + player.h - player.vy < e.y + 10) {
                    e.squished = true;
                    if (Math.random() < 0.25) items.push({ x: e.x + 4, y: e.y - 10, w: 24, h: 24, type: 'heart' });
                    player.vy = JUMP_FORCE / 1.5;
                } else if (!player.invincible) takeDamage();
            }
            if (Date.now() - e.lastShot > e.shootInterval && Math.abs(e.x - player.x) < 500) {
                arrows.push({ x: e.x, y: e.y + 15, vx: (player.x < e.x) ? -7 : 7, w: 20, h: 5 });
                e.lastShot = Date.now();
            }
        });

        items.forEach((item, i) => { if (checkCollision(player, item)) { if (item.type === 'heart') player.hp = Math.min(MAX_HP, player.hp + 1); items.splice(i, 1); updateUI(); } });
        arrows.forEach((a, i) => { a.x += a.vx; if (checkCollision(a, player)) { arrows.splice(i, 1); if (!player.invincible) takeDamage(); } });
        if (player.y > 600) endGame("FELL!");
    }

    function takeDamage() {
        player.hp--; player.invincible = true; updateUI();
        setTimeout(() => player.invincible = false, 1000);
        if (player.hp <= 0) endGame("CAUGHT!");
    }

    function endGame(reason) {
        AudioEngine.stop(); gameState = 'GAMEOVER'; gameOverScreen.style.display = 'flex'; ui.style.display = 'none';
        document.getElementById('death-title').innerText = reason;
        const prog = currentLevel === 1 ? Math.floor(score * 10) : Math.floor((score-405)*10);
        document.getElementById('final-stats').innerText = `Progress: ${prog}m.`;
    }

    function drawJames(x, y, facing, state = 'standing') {
        ctx.save(); ctx.translate(x + 16, y + 24);
        if (state === 'lying') ctx.rotate(Math.PI / 2); else ctx.scale(facing, 1);
        if (player.invincible && Math.floor(Date.now() / 100) % 2 === 0) ctx.globalAlpha = 0.5;
        ctx.fillStyle = '#5d4037'; ctx.fillRect(-12, -24, 24, 10);
        ctx.fillStyle = '#ffdbac'; ctx.fillRect(-10, -14, 20, 14);
        ctx.fillStyle = '#2196f3'; ctx.fillRect(-12, 0, 24, 20);
        ctx.fillStyle = '#3e2723'; ctx.fillRect(-12, 20, 24, 8);
        ctx.restore();
    }

    function drawKevin(x, y) {
        ctx.save(); ctx.translate(x + 16, y + 20);
        ctx.fillStyle = '#5d4037'; ctx.fillRect(-16, -20, 32, 40);
        ctx.fillStyle = '#111'; ctx.fillRect(-18, 0, 36, 12); 
        ctx.fillStyle = '#3e2723'; ctx.fillRect(-12, -30, 24, 15);
        ctx.fillStyle = '#333'; ctx.fillRect(kevin.dir > 0 ? 20 : -35, 10, 25, 8);
        ctx.fillStyle = 'red'; ctx.fillRect(-20, -45, 40, 5);
        ctx.fillStyle = 'green'; ctx.fillRect(-20, -45, (kevin.hp/3)*40, 5);
        ctx.restore();
    }

    function drawIslander(x, y, squished = false) {
        ctx.save(); ctx.translate(x + 16, y + 20);
        if (squished) { ctx.scale(1.5, 0.2); ctx.translate(0, 80); }
        ctx.fillStyle = '#5d4037'; ctx.fillRect(-16, -20, 32, 40);
        ctx.fillStyle = '#7cb342'; ctx.fillRect(-18, 0, 36, 12);
        ctx.fillStyle = '#3e2723'; ctx.fillRect(-12, -30, 24, 15);
        ctx.restore();
    }

    function drawBoat(x, y, scale = 1.0) {
        ctx.save(); ctx.translate(x, y); ctx.scale(scale, scale);
        ctx.fillStyle = '#795548'; ctx.beginPath();
        ctx.moveTo(0, 0); ctx.lineTo(100, 0); ctx.lineTo(80, 30); ctx.lineTo(20, 30);
        ctx.closePath(); ctx.fill();
        ctx.restore();
    }

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.save(); ctx.translate(-cameraX, 0);
        if (currentLevel === 1 && !['CUTSCENE2','CUTSCENE3','CUTSCENE4'].includes(gameState)) {
            ctx.fillStyle = '#2d5a27'; ctx.fillRect(cameraX, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#1a2f15';
            for(let i=0; i<15; i++) ctx.fillRect(cameraX + (i*200) - (cameraX*0.2 % 200), 50, 40, 400);
        } else { ctx.fillStyle = '#1565c0'; ctx.fillRect(cameraX, 0, canvas.width, canvas.height); }
        if (gameState === 'CUTSCENE1') {
            ctx.fillStyle = '#2e91e5'; ctx.fillRect(cameraX, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#f2d16b'; ctx.fillRect(cameraX, 350, canvas.width, 150);
        } else if (gameState.includes('CUTSCENE') || gameState === 'BOSS_BATTLE') {
            const boatScale = (gameState === 'BOSS_BATTLE') ? 0.7 : 1.0;
            drawBoat(boatPos.x, boatPos.y, boatScale);
            if (gameState === 'CUTSCENE4') { ctx.fillStyle = 'white'; ctx.fillRect(boatPos.x - 20, boatPos.y + 20, 20, 10); }
        }
        platforms.forEach(p => {
            ctx.fillStyle = (p.type === 'raft' || p.type === 'raft-arena') ? '#8d6e63' : (p.type === 'ground' ? '#3d2b1f' : '#5d4037');
            ctx.fillRect(p.x, p.y, p.w, p.h);
            if (p.type === 'raft' || p.type === 'raft-arena') { ctx.strokeStyle = '#3e2723'; for(let i=0; i<p.w; i+=20) ctx.strokeRect(p.x + i, p.y, 20, p.h); }
            else if (p.type !== 'ground') { ctx.fillStyle = '#4caf50'; ctx.fillRect(p.x, p.y, p.w, 8); }
        });
        items.forEach(item => { ctx.font = '24px Arial'; ctx.fillText('❤️', item.x, item.y + 20); });
        if (gameState.includes('CUTSCENE')) {
            drawJames(player.x, player.y, 1, (cutsceneTimer < 50 && gameState === 'CUTSCENE1') ? 'lying' : 'standing');
            ctx.fillStyle = '#ffffff'; ctx.fillRect(doctorPos.x, doctorPos.y, 32, 48);
            ctx.fillStyle = '#ffdbac'; ctx.fillRect(doctorPos.x+6, doctorPos.y-10, 20, 15);
            islandersCutscene.forEach(isl => { if(!isl.off) { if(isl.isKevin) drawKevin(isl.x, isl.y); else drawIslander(isl.x, isl.y); } });
        } else {
            if (gameState === 'BOSS_BATTLE') drawKevin(kevin.x, kevin.y);
            enemies.forEach(e => { drawIslander(e.x, e.y, e.squished); });
            arrows.forEach(a => { ctx.fillStyle = a.isBullet ? '#ffc107' : '#ffeb3b'; ctx.fillRect(a.x, a.y, a.w, a.h); });
            drawJames(player.x, player.y, player.facing);
        }
        ctx.restore();
        if (dialogue) {
            ctx.fillStyle = "rgba(0, 0, 0, 0.8)"; ctx.fillRect(50, canvas.height - 100, canvas.width - 100, 70);
            ctx.strokeStyle = "white"; ctx.strokeRect(50, canvas.height - 100, canvas.width - 100, 70);
            ctx.fillStyle = "white"; ctx.font = "bold 16px 'Courier New'"; ctx.textAlign = "center"; ctx.fillText(dialogue, canvas.width / 2, canvas.height - 60);
        }
        if (gameState === 'CUTSCENE4' && cutsceneTimer > DIALOGUE_DURATION + 260) {
            ctx.fillStyle = "yellow"; ctx.font = "bold 60px 'Courier New'"; ctx.textAlign = "center";
            ctx.fillText("THE END", canvas.width / 2, endTextY);
        }
    }
    window.addEventListener('resize', () => {
        const container = document.getElementById('game-container');
        canvas.width = container.clientWidth; canvas.height = container.clientHeight;
        draw();
    });
    window.dispatchEvent(new Event('resize'));
</script>
</body>
</html>
