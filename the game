        osc.frequency.setValueAtTime(30, audioCtx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(5, audioCtx.currentTime + 4);
        gain.gain.setValueAtTime(0, audioCtx.currentTime);
        gain.gain.linearRampToValueAtTime(0.25, audioCtx.currentTime + 1);
        gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 4);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + 4);
    }

