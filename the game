        "Anna's ribbon is now a leash. You'll never see her smile again.",
        "Spencer's garage tools couldn't save his son. Maggie's crying into the lye.",
        "Morgan fits in the crate. Anna fits in the jar. You fit in the furnace.",
        "The workshop gears are thirsty for Maggie and Spencer's grief.",
        "Your curly hair will look so festive on a North Pole shelf.",
        "The hooks are cold, Finn. But Spencer's blood is still warm.",
        "Anna is calling for a hero who is already becoming a doll."
    ];

    const world = {
        width: 1200, height: 1200,
        trees: [], snowflakes: [], hidingPlaces: [], footprints: [], shoes: [], breath: [], candyCanes: []
    };

    const player = { x: 600, y: 600, size: 22, speed: 8.4, sprintMultiplier: 1.7, isSprinting: false, isHidden: false, shoeTimer: 0, anim: 0 };
    const santa = { x: 300, y: 300, size: 45, speed: 3.4, baseSpeed: 3.4, targetX: 600, targetY: 600, anim: 0 };
    const keys = {};



   function initWorld() {
        world.trees = [];
        for (let i = 0; i < 22; i++) {
            world.trees.push({
                x: Math.random() * world.width, y: Math.random() * world.height,
                size: 70 + Math.random() * 50, color: `rgb(5, ${10 + Math.random() * 20}, 5)`,
                layers: 3 + Math.floor(Math.random() * 3)
            });
        }
        world.candyCanes = [];
        for (let i = 0; i < 15; i++) world.candyCanes.push({ x: Math.random() * world.width, y: Math.random() * world.height, rot: Math.random() * 0.6 - 0.3, height: 45 + Math.random() * 35 });
        world.shoes = [];
        for (let i = 0; i < 2; i++) world.shoes.push({ x: Math.random() * world.width, y: Math.random() * world.height, collected: false });
        world.hidingPlaces = [];
        for (let i = 0; i < 7; i++) world.hidingPlaces.push({ x: Math.random() * world.width, y: Math.random() * world.height, size: 80 + Math.random() * 40 });
        world.footprints = []; world.breath = []; world.snowflakes = [];
        for (let i = 0; i < 250; i++) world.snowflakes.push({ x: Math.random() * window.innerWidth, y: Math.random() * window.innerHeight, speed: 4.0 + Math.random() * 8 });
    }



   function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; jCanvas.width = window.innerWidth; jCanvas.height = window.innerHeight; }
    window.addEventListener('resize', resize); resize();
    window.addEventListener('keydown', (e) => { keys[e.code] = true; if (e.code.includes('Shift')) player.isSprinting = true; });
    window.addEventListener('keyup', (e) => { keys[e.code] = false; if (e.code.includes('Shift')) player.isSprinting = false; });

    function drawFootprints(ctx) {
        ctx.save();
        for (let f of world.footprints) { ctx.globalAlpha = f.life; ctx.fillStyle = '#cbd5e0'; ctx.beginPath(); ctx.ellipse(f.x + (f.side * 5), f.y, 4, 7, f.angle, 0, Math.PI * 2); ctx.fill(); }
        ctx.restore();
    }

    function drawBreath() {
        ctx.save();
        for(let b of world.breath) { ctx.globalAlpha = b.life * 0.4; ctx.fillStyle = 'white'; ctx.beginPath(); ctx.arc(b.x, b.y, b.size, 0, Math.PI * 2); ctx.fill(); }
        ctx.restore();
    }

    function drawTree(t) {
        ctx.fillStyle = '#3d251e'; ctx.fillRect(t.x - 7, t.y, 14, 25);


       ctx.fillStyle = '#2d1b16'; ctx.fillRect(t.x - 7, t.y, 4, 25);
        for(let i = 0; i < t.layers; i++) {
            const yPos = t.y - (i * (t.size / t.layers));
            const layerWidth = t.size - (i * 20);
            const grad = ctx.createLinearGradient(t.x - layerWidth/2, yPos, t.x + layerWidth/2, yPos);
            grad.addColorStop(0, t.color); grad.addColorStop(0.5, '#052a05'); grad.addColorStop(1, t.color);
            ctx.fillStyle = grad; ctx.beginPath(); ctx.moveTo(t.x, yPos - (t.size / 2)); ctx.lineTo(t.x - layerWidth/2, yPos); ctx.lineTo(t.x + layerWidth/2, yPos); ctx.fill();
        }
    }

    function drawCandyCane(cc) {
        ctx.save(); ctx.translate(cc.x, cc.y); ctx.rotate(cc.rot);
        ctx.lineCap = 'round'; ctx.lineWidth = 11; ctx.strokeStyle = '#e0e0e0';
        ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(0, -cc.height); ctx.arc(12, -cc.height, 12, Math.PI, 0); ctx.stroke();
        ctx.strokeStyle = '#8b0000'; ctx.setLineDash([6, 12]);
        ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(0, -cc.height); ctx.arc(12, -cc.height, 12, Math.PI, 0); ctx.stroke();
        ctx.setLineDash([]); ctx.restore();
    }



   function drawPlayer(x, y) {
        if (player.isHidden) ctx.globalAlpha = 0.4;
        const bob = Math.abs(Math.sin(player.anim)) * 3;
        const legSwing = Math.sin(player.anim) * 12;
        ctx.fillStyle = 'rgba(0,0,0,0.5)'; ctx.beginPath(); ctx.ellipse(x, y + 20, 14, 6, 0, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = '#0a1a2a'; ctx.fillRect(x - 8 + (legSwing / 2), y + 15, 6, 12); ctx.fillRect(x + 2 - (legSwing / 2), y + 15, 6, 12);
        ctx.fillStyle = '#0a1a2a'; ctx.fillRect(x - 12, y - 5 - bob, 24, 28);
        ctx.fillStyle = '#c8a494'; ctx.fillRect(x - 16, y + 5 - bob + (legSwing / 3), 6, 10); ctx.fillRect(x + 10, y + 5 - bob - (legSwing / 3), 6, 10);
        ctx.fillStyle = '#c8a494'; ctx.beginPath(); ctx.arc(x, y - 12 - bob, 11, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = '#2d1b16';
        for(let i = 0; i < 12; i++) {
            const angle = (i / 12) * Math.PI - Math.PI;
            ctx.beginPath(); ctx.arc(x + Math.cos(angle) * 10, y - 16 - bob + Math.sin(angle) * 8, 7, 0, Math.PI * 2); ctx.fill();
        }
        ctx.globalAlpha = 1.0;
    }

    function drawSanta(x, y) {
        const bob = Math.abs(Math.sin(santa.anim)) * 5;


       const swing = Math.sin(santa.anim) * 15;
        ctx.fillStyle = 'rgba(0,0,0,0.6)'; ctx.beginPath(); ctx.ellipse(x, y + 45, 25, 10, 0, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = '#3a0000'; 
        ctx.beginPath(); ctx.moveTo(x - 25 - (swing/4), y + 40); ctx.lineTo(x + 25 + (swing/4), y + 40); ctx.lineTo(x + 20, y - 15 - bob); ctx.lineTo(x - 20, y - 15 - bob); ctx.fill();
        ctx.fillStyle = '#2a0000'; ctx.fillRect(x - 30, y + (swing/2) - bob, 10, 20); ctx.fillRect(x + 20, y - (swing/2) - bob, 10, 20);
        ctx.fillStyle = '#a48464'; ctx.beginPath(); ctx.arc(x, y - 10 - bob, 15, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = '#ff0000'; ctx.shadowBlur = 20; ctx.shadowColor = 'red';
        ctx.beginPath(); ctx.arc(x - 6, y - 12 - bob, 1.8, 0, Math.PI * 2); ctx.arc(x + 6, y - 12 - bob, 1.8, 0, Math.PI * 2); ctx.fill(); ctx.shadowBlur = 0; 
        ctx.fillStyle = '#444'; ctx.beginPath(); ctx.moveTo(x - 14, y - 5 - bob); ctx.lineTo(x + (swing/5), y + 45 - bob); ctx.lineTo(x + 14, y - 5 - bob); ctx.fill();
    }

    function showMessage(text) { messageBox.innerHTML = `&ldquo;${text}&rdquo;`; messageBox.style.display = 'flex'; setTimeout(() => { if (messageBox.innerHTML === `“${text}”`) messageBox.style.display = 'none'; }, 4000); }

    function triggerMagicBlackout() {
        if (isMagicBlackout) return;
        isMagicBlackout = true; playMagicSound();
        showMessage(blackoutDialogue[Math.floor(Math.random() * blackoutDialogue.length)]);
        setTimeout(() => { isMagicBlackout = false; }, 3500);
    }



   function startGame() {
        initAudio(); gameActive = true; startTime = Date.now(); lastHeartbeatTime = Date.now(); lastDialogueTime = Date.now(); lastBlackoutTime = Date.now();
        overlay.style.display = 'none'; jCanvas.style.display = 'none'; isMagicBlackout = false; player.shoeTimer = 0;
        player.x = 200 + Math.random() * (world.width - 400); player.y = 200 + Math.random() * (world.height - 400);
        const dist = 450 + Math.random() * 100; const angle = Math.random() * Math.PI * 2;
        santa.x = player.x + Math.cos(angle) * dist; santa.y = player.y + Math.sin(angle) * dist;
        if (scaryMusic) { scaryMusic.gain.gain.linearRampToValueAtTime(0.4, audioCtx.currentTime + 1); scaryMusic.startGhostly(); }
        initWorld(); requestAnimationFrame(gameLoop);
        showMessage("RUN, FINN. THE MEAT-HOOKS ARE READY.");
    }

    function triggerJumpscare() {
        playJumpscareSound(); gameActive = false; jCanvas.style.display = 'block'; gameContainer.classList.add('shake');
        let jumpFrames = 0;
        const jumpLoop = () => {
            if(jumpFrames < 140) { 
                const w = jCanvas.width, h = jCanvas.height; jCtx.clearRect(0,0,w,h); jCtx.fillStyle = 'black'; jCtx.fillRect(0,0,w,h);
                const cX = w/2 + (Math.random()*30-15), cY = h/2 + (Math.random()*30-15);
                const grad = jCtx.createRadialGradient(cX, cY, 50, cX, cY, 450); grad.addColorStop(0, '#3a1b0b'); grad.addColorStop(0.7, '#1a0500'); grad.addColorStop(1, '#000');


               jCtx.fillStyle = grad; jCtx.beginPath(); jCtx.ellipse(cX, cY, 300, 400, 0, 0, Math.PI*2); jCtx.fill();
                jCtx.fillStyle = '#000'; jCtx.beginPath(); jCtx.arc(cX - 100, cY - 80, 70, 0, Math.PI*2); jCtx.arc(cX + 100, cY - 80, 70, 0, Math.PI*2); jCtx.fill();
                jCtx.fillStyle = '#ff0000'; jCtx.shadowBlur = 50; jCtx.shadowColor = 'red'; jCtx.beginPath(); jCtx.arc(cX - 100, cY - 80, 10, 0, Math.PI*2); jCtx.arc(cX + 100, cY - 80, 10, 0, Math.PI*2); jCtx.fill();
                jumpFrames++; requestAnimationFrame(jumpLoop);
            } else {
                jCanvas.style.display = 'none'; gameContainer.classList.remove('shake');
                overlay.style.display = 'flex'; overlayTitle.innerText = "ABDUCTED";
                const randMsg = abductionMessages[Math.floor(Math.random() * abductionMessages.length)];
                overlayDesc.innerHTML = `<span style="color: #ff3333; font-style: italic;">${randMsg}</span><br><br>Spencer and Maggie's house is finally quiet.<br><br><strong>Survival: ${timerEl.innerText}s</strong>`;
                startBtn.innerText = "Escape Again";
            }
        }; jumpLoop();
    }

    function gameLoop() { if (!gameActive) return; update(); draw(); requestAnimationFrame(gameLoop); }

    function update() {
        let moveX = 0, moveY = 0;
        if (keys['KeyW']) moveY -= 1; if (keys['KeyS']) moveY += 1; if (keys['KeyA']) moveX -= 1; if (keys['KeyD']) moveX += 1;


       const currentSpeed = player.isSprinting ? player.speed * player.sprintMultiplier : player.speed;
        if (moveX !== 0 || moveY !== 0) {
            const length = Math.sqrt(moveX * moveX + moveY * moveY);
            player.x += (moveX / length) * currentSpeed; player.y += (moveY / length) * currentSpeed;
            player.anim += player.isSprinting ? 0.44 : 0.3;
            if (player.shoeTimer <= 0 && Date.now() - lastFootprintTime > 90) { playFootstep(); world.footprints.push({ x: player.x, y: player.y, life: 1.0, side: world.footprints.length % 2 === 0 ? 1 : -1, angle: Math.atan2(moveY, moveX) }); lastFootprintTime = Date.now(); }
        } else { player.anim = 0; }
        if (Math.random() < 0.06) world.breath.push({ x: player.x + (Math.random()*4-2), y: player.y - 15, size: 2, life: 1.0, vx: (Math.random() - 0.5) * 0.5, vy: -0.3 - Math.random() * 0.5 });
        for(let i = world.breath.length - 1; i >= 0; i--) { const b = world.breath[i]; b.x += b.vx; b.y += b.vy; b.life -= 0.03; b.size += 0.2; if (b.life <= 0) world.breath.splice(i, 1); }
        player.x = Math.max(0, Math.min(world.width, player.x)); player.y = Math.max(0, Math.min(world.height, player.y));
        world.shoes.forEach(s => { if(!s.collected && Math.sqrt((player.x-s.x)**2 + (player.y-s.y)**2) < 40) { s.collected = true; player.shoeTimer = 15; playPowerUpSound(); showMessage("Ghost steps active. Maggie won't hear you scream."); } });
        if(player.shoeTimer > 0) { player.shoeTimer -= 1/60; shoeValEl.innerText = Math.max(0, player.shoeTimer).toFixed(1); shoeTimerContainer.style.display = 'block'; } else { shoeTimerContainer.style.display = 'none'; }
        player.isHidden = false;
        world.hidingPlaces.forEach(hp => { if (Math.sqrt((player.x - hp.x)**2 + (player.y - hp.y)**2) < hp.size - 10) player.isHidden = true; });
        hidingIndicator.style.display = player.isHidden ? 'block' : 'none';
        for(let f of world.footprints) f.life -= 0.003; world.footprints = world.footprints.filter(f => f.life > 0);
        if (!player.isHidden) { santa.targetX = player.x; santa.targetY = player.y; }
        else if (world.footprints.length > 0) { const lp = world.footprints[world.footprints.length - 1]; santa.targetX = lp.x; santa.targetY = lp.y; }
        const sdx = santa.targetX - santa.x, sdy = santa.targetY - santa.y, sdist = Math.sqrt(sdx*sdx + sdy*sdy);


       if (sdist > 5) { santa.x += (sdx / sdist) * santa.speed; santa.y += (sdy / sdist) * santa.speed; santa.anim += 0.24; }
        const timeElapsed = (Date.now() - startTime) / 1000;
        santa.speed = 3.4 + (timeElapsed * 0.04); 
        const currentDist = Math.sqrt((player.x - santa.x)**2 + (player.y - santa.y)**2);
        distanceEl.innerText = Math.floor(currentDist); timerEl.innerText = Math.floor(timeElapsed);
        if (Date.now() - lastHeartbeatTime > Math.max(150, Math.min(1200, currentDist * 1.5))) { playHeartbeat(Math.max(0.1, Math.min(0.7, 1.0 - (currentDist / 800)))); lastHeartbeatTime = Date.now(); }
        if (!isMagicBlackout && Date.now() - lastDialogueTime > 5000) { showMessage(chaseDialogue[Math.floor(Math.random() * chaseDialogue.length)]); lastDialogueTime = Date.now(); }
        if (Date.now() - lastBlackoutTime > 40000) { triggerMagicBlackout(); lastBlackoutTime = Date.now(); }
        if (parseInt(distanceEl.innerText) < player.size + santa.size - 15) triggerJumpscare();
    }

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        if (isMagicBlackout) { ctx.fillStyle = 'black'; ctx.fillRect(0, 0, canvas.width, canvas.height); return; }
        const camX = canvas.width / 2 - player.x, camY = canvas.height / 2 - player.y;
        ctx.save(); ctx.translate(camX, camY); ctx.fillStyle = '#fdfdfd'; ctx.fillRect(0, 0, world.width, world.height);
        drawFootprints(ctx); drawBreath(); world.shoes.forEach(s => drawShoe(s)); world.hidingPlaces.forEach(hp => drawHidingPlace(hp));
        world.candyCanes.forEach(cc => drawCandyCane(cc)); world.trees.forEach(t => drawTree(t));
        drawSanta(santa.x, santa.y); drawPlayer(player.x, player.y); ctx.restore();


       const flashlight = ctx.createRadialGradient(canvas.width/2, canvas.height/2, 20, canvas.width/2, canvas.height/2, 380);
        flashlight.addColorStop(0, 'rgba(0,0,0,0)'); flashlight.addColorStop(1, 'rgba(0,0,0,0.99)');
        ctx.fillStyle = flashlight; ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = 'rgba(200, 200, 200, 0.7)'; world.snowflakes.forEach(s => { ctx.beginPath(); ctx.arc(s.x, s.y, 1.5, 0, Math.PI * 2); ctx.fill(); });
    }
    function drawShoe(s) { if(s.collected) return; ctx.fillStyle = '#2d1b16'; ctx.fillRect(s.x-10, s.y-5, 20, 10); ctx.fillRect(s.x-10, s.y-12, 8, 12); }
    function drawHidingPlace(hp) { ctx.fillStyle = '#cbd5e0'; ctx.beginPath(); ctx.arc(hp.x, hp.y, hp.size, 0, Math.PI * 2); ctx.fill(); }
    initWorld();
</script>
