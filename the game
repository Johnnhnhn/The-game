<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>North Pole Escape</title>
    <style>
        :root {
            --bg-color: #050505;
            --text-color: #e0e0e0;
            --accent-color: #8b0000;
        }

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;


           background-color: var(--bg-color);
            font-family: 'Courier New', Courier, monospace;
            color: var(--text-color);
            user-select: none;
            touch-action: none;
        }

        #game-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        canvas {
            display: block;
            background: #ffffff;


           box-shadow: 0 0 50px rgba(0,0,0,0.8);
            cursor: none;
        }

        #ui-layer {
            position: absolute;
            top: 20px;
            left: 20px;
            pointer-events: none;
            z-index: 5;
        }

        .stats {
            font-size: 1.1rem;
            text-shadow: 2px 2px 4px #000;
            margin-bottom: 5px;
            letter-spacing: 1px;
            color: #d1d1d1;
        }



       #overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 20;
            text-align: center;
            padding: 20px;
        }

        h1 {
            color: var(--accent-color);
            font-size: 3.5rem;


           margin-bottom: 10px;
            letter-spacing: 8px;
            text-transform: uppercase;
            text-shadow: 0 0 20px rgba(139, 0, 0, 0.8);
        }

        p {
            font-size: 1.1rem;
            margin-bottom: 30px;
            max-width: 600px;
            line-height: 1.6;
            color: #aaa;
        }

        .btn {
            background: transparent;
            border: 1px solid var(--accent-color);
            color: var(--text-color);
            padding: 15px 45px;


           font-size: 1.3rem;
            cursor: pointer;
            transition: all 0.4s;
            text-transform: uppercase;
            letter-spacing: 3px;
        }

        .btn:hover {
            background: var(--accent-color);
            color: white;
            box-shadow: 0 0 30px var(--accent-color);
        }

        #message-box {
            position: absolute;
            bottom: 60px;
            left: 50%;
            transform: translateX(-50%);
            width: 90%;


           max-width: 800px;
            background: rgba(10, 0, 0, 0.9);
            border-left: 5px solid #8b0000;
            padding: 25px;
            display: none;
            color: #ff3333;
            font-weight: bold;
            font-size: 1.2rem;
            animation: glitchFade 0.3s;
            text-align: center;
            z-index: 15;
            min-height: 70px;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 20px rgba(0,0,0,1);
        }

        #hiding-indicator {
            position: absolute;


           top: 20px;
            right: 20px;
            color: #1b5e20;
            font-weight: bold;
            display: none;
            text-shadow: 0 0 10px #1b5e20;
            z-index: 5;
        }

        #shoe-timer {
            position: absolute;
            bottom: 20px;
            right: 20px;
            color: #b8860b;
            font-weight: bold;
            display: none;
            text-shadow: 0 0 10px #000;
            z-index: 5;
        }



       #jumpscare-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 100;
            display: none;
            background: black;
        }

        .shake {
            animation: shakeScreen 0.04s infinite;
        }

        @keyframes shakeScreen {
            0% { transform: translate(15px, 15px); }
            25% { transform: translate(-15px, -15px); }
            50% { transform: translate(-15px, 15px); }


           75% { transform: translate(15px, -15px); }
            100% { transform: translate(0, 0); }
        }

        @keyframes glitchFade {
            0% { opacity: 0; transform: translateX(-52%) scaleY(0.1); }
            50% { opacity: 0.8; transform: translateX(-49%) scaleY(1.2); }
            100% { opacity: 1; transform: translateX(-50%) scaleY(1); }
        }
    </style>
</head>
